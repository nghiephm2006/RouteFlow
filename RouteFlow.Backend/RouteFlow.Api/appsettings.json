{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=routeflow;Username=postgres;Password=__SET_VIA_ENV_OR_USER_SECRETS__"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:8080"
    ]
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Features": {
    "EnableSwagger": true
  },
  "Auth": {
    "Jwt": {
      "Issuer": "RouteFlow",
      "Audience": "RouteFlowClient",
      "SigningKey": "__SET_VIA_ENV_OR_USER_SECRETS_MIN_32_CHARS__",
      "AccessTokenMinutes": 480
    },
    "BootstrapAdmin": {
      "Email": "",
      "Password": "",
      "FullName": "RouteFlow Admin",
      "UserName": "admin"
    }
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromName": "RouteFlow System",
    "FromEmail": ""
  }
}
